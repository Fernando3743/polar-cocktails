# Polar — environment variables
# Copy this file to .env.local and fill in the values from your Supabase project.
# When the two NEXT_PUBLIC_SUPABASE_* values are absent, the app runs in seed/demo
# mode: the storefront uses bundled seed data and the admin/auth area is disabled.

# Supabase project URL (Project Settings -> API -> Project URL). Public.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (Project Settings -> API -> anon public). Public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (Project Settings -> API -> service_role). SERVER ONLY.
# Never expose this to the browser. Read by lib/supabase/admin.ts to create and
# manage admin users (the Administradores panel). Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Email of the single SUPER admin (the owner). Server-only, never NEXT_PUBLIC.
# This user can create/manage other admins from /admin/admins and can never be
# locked out or removed via the UI. Regular admins are created in-app and are
# identified by app_metadata.role='admin' (no env entry per admin). Keep public
# sign-ups disabled in the Supabase dashboard.
SUPER_ADMIN_EMAIL=

# Absolute production origin for SEO (OG/canonical/sitemap/robots/JSON-LD). Public.
# Set this to the production domain on Vercel, e.g. https://polar.example.co
# Absent it, falls back to VERCEL_URL, then http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Set to 1 in Vercel production to enable analytics. Empty/absent disables it. Public.
NEXT_PUBLIC_ANALYTICS=

# Public URL of the home hero video (uploaded to the Supabase site-assets storage
# bucket). Optional — when unset the component falls back to a local public/*.mov,
# which is gitignored, so set this in any deployed environment. Public.
NEXT_PUBLIC_HOME_VIDEO_URL=
